    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "chalk": "latest",
    "commander": "latest",
    "pixelmatch": "latest",
    "playwright": "latest",
    "pngjs": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pngjs": "latest",
    "c8": "^11.0.0",
    "tsx": "latest",
    "typescript": "latest"
  }
}
