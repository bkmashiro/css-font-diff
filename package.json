{
  "name": "css-font-diff",
  "version": "0.5.0",
  "type": "module",
  "bin": {
    "css-font-diff": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx/esm src/index.ts",
